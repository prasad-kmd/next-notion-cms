# GitHub Personal Access Token (optional)
# Increases API rate limit from 60 to 5,000 requests/hour
# Get your token at: https://github.com/settings/tokens/new
# Required scopes: public_repo (read-only access to public repositories)
NEXT_PUBLIC_GITHUB_TOKEN=your_github_token_here

# NotionCMS
NOTION_ROOT_PAGE_ID=
NOTION_BLOG_ID=
NOTION_ARTICLES_ID=
NOTION_PROJECTS_ID=
NOTION_TUTORIALS_ID=
NOTION_WIKI_ID=
NOTION_AUTH_TOKEN=
NOTION_AUTHORS_ID=

NEXT_TELEMETRY_DISABLED=1

# Entertainment
OMDB_API=
# YTS_API=https://movies-api.accel.li/api/v2/
TMDB_API_KEY=

# Site Public Production URL
SITE_URL=Production_url

# Site Contact via Telegram
TELEGRAM_TOKEN=tg_bot_token
TELEGRAM_CHAT_ID=private_groupchat_id

# Social Media Links
NEXT_PUBLIC_GITHUB_USERNAME=prasad-kmd
NEXT_PUBLIC_GITHUB_URL=https://github.com/prasad-kmd
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/prasadmadhuran1
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/prasad-madhuranga
NEXT_PUBLIC_EMAIL=contact@prasadm.vercel.app
NEXT_PUBLIC_GITHUB_SPONSORS_URL=https://github.com/sponsors/prasad-kmd

NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
# sample on https://www.magicbell.com/tools/vapid-keys
# https://knock.app/tools/vapid-key-generator

DATABASE_URL=your_URI_of_db(supabase_recommended)

BETTER_AUTH_SECRET=your_32_char_secret
## You may run following command to generate a random string: 
## PowerShell: 
## [Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
BETTER_AUTH_URL=http://localhost:3000

GOOGLE_CLIENT_ID=your_client_id_from_google_cloud_console
GOOGLE_CLIENT_SECRET=your_client_secret_from_google_cloud_console

GITHUB_CLIENT_ID=your_client_id_from_github_developer_settings
GITHUB_CLIENT_SECRET=your_client_secret_from_github_developer_settings

# PostHog Analytics
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Cloudflare Turnstile CAPTCHA
# Site key for client-side: https://developers.cloudflare.com/turnstile/get-started/
# For local development, use these test keys:
# Site key (always passes): 1x00000000000000000000AA
# Secret key (always passes): 1x0000000000000000000000000000000AA
# Other test keys:
# Always fails: Site key 2x00000000000000000000AB, Secret 2x0000000000000000000000000000000AA
# Forces interactive: Site key 3x00000000000000000000FF
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA