# GitHub Personal Access Token (optional)
# Increases API rate limit from 60 to 5,000 requests/hour
# Get your token at: https://github.com/settings/tokens/new
# Required scopes: public_repo (read-only access to public repositories)
NEXT_PUBLIC_GITHUB_TOKEN=your_github_token_here

# NotionCMS
NOTION_ROOT_PAGE_ID=
NOTION_BLOG_ID=
NOTION_ARTICLES_ID=
NOTION_PROJECTS_ID=
NOTION_TUTORIALS_ID=
NOTION_WIKI_ID=
NOTION_AUTH_TOKEN=
NOTION_AUTHORS_ID=

NEXT_TELEMETRY_DISABLED=1

# Entertainment
# OMDB_API=
# YTS_API=https://movies-api.accel.li/api/v2/
# TMDB_API_KEY=

# Site Public Production URL
SITE_URL=Production_url

# Site Contact via Telegram
TELEGRAM_TOKEN=tg_bot_token
TELEGRAM_CHAT_ID=private_groupchat_id

# Social Media Links
